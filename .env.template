# Project APE Environment Variables
# Copy this file to .env and fill in your actual values

# ==============================================================================
# GOOGLE DRIVE SERVICE ACCOUNT (Required)
# ==============================================================================
# Service account JSON key file for Google Drive API access
#
# NOTE: This path is INSIDE THE CONTAINER (not your host machine path)
# The launch_ape.sh script automatically mounts your service account file
# from your host to /app/service-account.json in the container
#
# How to create: See SERVICE-ACCOUNT-SETUP.md
# Host file location: Should be in the Project-APE directory (e.g., yourfile.json)
#
GOOGLE_DRIVE_SERVICE_ACCOUNT_KEY=/app/service-account.json
