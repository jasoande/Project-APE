# Project APE Environment Variables

# ==============================================================================
# GEMINI API (Required for Agent Orchestration)
# ==============================================================================
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ==============================================================================
# GOOGLE DRIVE (Optional - for downloading client data from Drive)
# ==============================================================================
# Path to service account JSON key file (CONTAINER path when using launch_ape.sh)
# The actual file is mounted from host at runtime via launch_ape.sh
GOOGLE_DRIVE_SERVICE_ACCOUNT_KEY=/app/service-account.json
